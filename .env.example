# Mau cau hinh - COPY file nay thanh .env roi dien gia tri cua ban.
#   cp .env.example .env   (hoac copy tay tren Windows)
# File .env that da bi gitignore, KHONG commit.

# --- Bat buoc ---
JIRA_SITE=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=tao-tai-id.atlassian.com (Security -> API tokens)

# --- Tuy chon (co mac dinh neu bo trong) ---
# Project key de loc su kien webhook (mac dinh: SCRUM)
# JIRA_PROJECT=SCRUM
# Ten webhook rieng cua dev (mac dinh: "AI ticket demo - <phan truoc @ cua email>")
# JIRA_WEBHOOK_NAME=AI ticket demo - ten-cua-ban
